# OS
.DS_Store
Thumbs.db

# Foundry build artifacts
contracts/cache/
contracts/out/
contracts/broadcast/
contracts/build-info/
# Stray foundry artifacts at repo root (when forge is run from cwd != contracts/)
/cache/
/out/

# Noir build artifacts (regenerable from src/ with `nargo compile`)
circuits/*/target/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.python-version

# Runtime artifacts produced by tools/
runs/

# Local secrets — NEVER commit
.env
*.env.local
tools/test_keys.json

# Editor
.vscode/
.idea/
*.swp

# Logs
*.log

# Local-only refactor planning workspace; never pushed
STAGING_REFACTOR/

# Local-only omp coding-agent project tooling (extensions, dry-run logs)
.omp/

# Helper Prover.toml files are transient dispatch buffers, rewritten on each
# poseidon2_state / keystream call. Track only `*.example` files for these.
circuits/_poseidon2_state_helper/Prover.toml
circuits/_ecies_keystream_helper/Prover.toml
circuits/*/target/
circuits/mutate_slot/Prover.toml
circuits/zindex_commit/Prover.toml
circuits/shadow_t10/Prover.toml
circuits/transfer_shadow_v2/Prover.toml
circuits/solve_shadow_v2/Prover.toml
circuits/landmark_regions_v2/Prover.toml
# Audit M-11: secret_inbox writes plaintext+key+nonce into Prover.toml.
# Track only the .example variant; never commit a real prove cycle's inputs.
circuits/secret_inbox/Prover.toml


# Local audit outputs
/audit/

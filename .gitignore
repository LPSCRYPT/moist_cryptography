# OS
.DS_Store
Thumbs.db

# Foundry build artifacts
contracts/cache/
contracts/out/
contracts/broadcast/
contracts/build-info/

# Noir build artifacts (regenerable from src/ with `nargo compile`)
circuits/*/target/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.python-version

# Runtime artifacts produced by tools/
runs/

# Local secrets — NEVER commit
.env
*.env.local
tools/test_keys.json

# Editor
.vscode/
.idea/
*.swp

# Logs
*.log

# Local-only refactor planning workspace; never pushed
STAGING_REFACTOR/

# Helper Prover.toml files are transient dispatch buffers, rewritten on each
# poseidon2_state / keystream call. Track only `*.example` files for these.
circuits/_poseidon2_state_helper/Prover.toml
circuits/_ecies_keystream_helper/Prover.toml
circuits/*/target/
circuits/mutate_slot/Prover.toml
circuits/zindex_commit/Prover.toml
